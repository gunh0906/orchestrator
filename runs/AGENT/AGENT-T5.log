+    def _on_runtime_ready(self, payload: object) -> None:
+        self._runtime_inflight = False
+        machine = self._selected_machine() or "MonitorServer"
+        try:
+            body = payload if isinstance(payload, dict) else _bootstrap_payload()
+            body = self._apply_runtime_history_payload(machine=machine, payload=body)
+            self._dialog.set_payload(machine=machine, payload=body if isinstance(body, dict) else _bootstrap_payload())
+            self._set_status("연결됨", state="connected")
+        except Exception as exc:
+            self._set_status(f"payload error ({exc})", state="error")
+
+    def _on_runtime_error(self, message: str) -> None:
+        self._runtime_inflight = False
+        msg = str(message or "").strip()
+        if len(msg) > 120:
+            msg = msg[:117] + "..."
+        self._set_status(msg or "runtime error", state="warning")

