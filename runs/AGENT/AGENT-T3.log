+def _safe_int(value: Any, default: int) -> int:
+    try:
+        return int(value)
+    except Exception:
+        return int(default)
+
+
+def _safe_float(value: Any, default: float) -> float:
+    try:
+        return float(value)
+    except Exception:
+        return float(default)
+
+
+def _normalized_server_control_settings(raw: dict[str, Any]) -> dict[str, Any]:
+    defaults = _default_server_control_settings_payload()
+    row = dict(raw or {})
+
+    host = str(row.get("listen_host", defaults["listen_host"]) or defaults["listen_host"]).strip()
+    if not host:
+        host = str(defaults["listen_host"])
+
+    port = _safe_int(row.get("port", defaults["port"]), int(defaults["port"]))
+    if port <= 0:
+        port = int(defaults["port"])
+
+    runtime_db = str(row.get("runtime_db", defaults["runtime_db"]) or defaults["runtime_db"]).strip()
+    if not runtime_db:
+        runtime_db = str(defaults["runtime_db"])
+
+    connections_json = str(
+        row.get("connections_json", defaults["connections_json"]) or defaults["connections_json"]
+    ).strip()
+    if not connections_json:
+        connections_json = str(defaults["connections_json"])
+
+    collector_interval_sec = _safe_int(
+        row.get("collector_interval_sec", defaults["collector_interval_sec"]),
+        int(defaults["collector_interval_sec"]),
+    )
+    collector_interval_sec = max(1, min(60, int(collector_interval_sec)))
+
+    auto_open_home = bool(row.get("auto_open_home", defaults["auto_open_home"]))
+
+    home_wait_timeout_sec = _safe_int(
+        row.get("home_wait_timeout_sec", defaults["home_wait_timeout_sec"]),
+        int(defaults["home_wait_timeout_sec"]),
+    )
+    home_wait_timeout_sec = max(5, min(180, int(home_wait_timeout_sec)))
+
+    home_wait_step_sec = _safe_float(
+        row.get("home_wait_step_sec", defaults["home_wait_step_sec"]),
+        float(defaults["home_wait_step_sec"]),
+    )
+    home_wait_step_sec = max(0.1, min(5.0, float(home_wait_step_sec)))
+
+    return {
+        "schema_version": 1,
+        "generated_at": datetime.now().isoformat(timespec="seconds"),
+        "listen_host": host,
+        "port": int(port),
+        "runtime_db": runtime_db,
+        "connections_json": connections_json,
+        "collector_interval_sec": int(collector_interval_sec),
+        "auto_open_home": bool(auto_open_home),
+        "home_wait_timeout_sec": int(home_wait_timeout_sec),
+        "home_wait_step_sec": float(home_wait_step_sec),
+    }
