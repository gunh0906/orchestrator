+def default_server_settings() -> dict[str, Any]:
+    return {
+        "port": 8866,
+        "runtime_db_path": str(runtime_db_path()),
+        "connections_json_path": str(monitor_connection_file_path()),
+        "fleet_log_dir": str(_repo_root() / "runs" / "fleet_logs"),
+        "status_refresh_interval_sec": 3,
+    }
+
+
+def _normalize_path_text(value: Any) -> str:
+    txt = str(value or "").strip()
+    if not txt:
+        return ""
+    try:
+        return str(Path(txt).expanduser())
+    except Exception:
+        return txt
+
+
+def _validate_path_setting(
+    value: Any,
+    *,
+    label: str,
+    expects_dir: bool,
+    create_missing_paths: bool,
+) -> tuple[str, str | None]:
+    raw = _normalize_path_text(value)
+    if not raw:
+        return "", f"{label}: value is required."
+
+    target = Path(raw)
+    check_dir = target if expects_dir else target.parent
+    if not str(check_dir or "").strip():
+        return "", f"{label}: parent path is invalid."
+
+    try:
+        if create_missing_paths:
+            check_dir.mkdir(parents=True, exist_ok=True)
+        elif not check_dir.exists():
+            return "", f"{label}: parent path does not exist ({check_dir})."
+    except Exception as exc:
+        return "", f"{label}: path is not writable ({check_dir}) - {exc}"
+
+    if expects_dir and target.exists() and (not target.is_dir()):
+        return "", f"{label}: expected a directory path, got file ({target})."
+    if (not expects_dir) and target.exists() and target.is_dir():
+        return "", f"{label}: expected a file path, got directory ({target})."
+    return str(target), None
+
+
+def validate_server_settings(
+    settings: dict[str, Any] | None,
+    *,
+    create_missing_paths: bool = True,
+) -> tuple[dict[str, Any], list[str]]:
+    merged = dict(default_server_settings())
+    merged.update(dict(settings or {}))
+    errors: list[str] = []
+
+    raw_port = merged.get("port", None)
+    try:
+        port = int(raw_port)
+    except Exception:
+        errors.append(
+            f"Server port must be an integer in {_SERVER_PORT_MIN}-{_SERVER_PORT_MAX}."
+        )
+        port = int(default_server_settings()["port"])
+    if not (_SERVER_PORT_MIN <= int(port) <= _SERVER_PORT_MAX):
+        errors.append(
+            f"Server port must be in {_SERVER_PORT_MIN}-{_SERVER_PORT_MAX} (current: {port})."
+        )
+        port = int(default_server_settings()["port"])
+    merged["port"] = int(port)
+
+    raw_interval = merged.get("status_refresh_interval_sec", None)
+    try:
+        interval_sec = int(raw_interval)
+    except Exception:
+        errors.append(
+            f"Status refresh interval must be an integer in {_SERVER_INTERVAL_MIN}-{_SERVER_INTERVAL_MAX} seconds."
+        )
+        interval_sec = int(default_server_settings()["status_refresh_interval_sec"])
+    if not (_SERVER_INTERVAL_MIN <= int(interval_sec) <= _SERVER_INTERVAL_MAX):
+        errors.append(
+            f"Status refresh interval must be in {_SERVER_INTERVAL_MIN}-{_SERVER_INTERVAL_MAX} seconds (current: {interval_sec})."
+        )
+        interval_sec = int(default_server_settings()["status_refresh_interval_sec"])
+    merged["status_refresh_interval_sec"] = int(interval_sec)
+
+    for key, label, expects_dir in (
+        ("runtime_db_path", "Runtime DB path", False),
+        ("connections_json_path", "Connections JSON path", False),
+        ("fleet_log_dir", "Fleet log directory", True),
+    ):
+        normalized, err = _validate_path_setting(
+            merged.get(key),
+            label=label,
+            expects_dir=bool(expects_dir),
+            create_missing_paths=create_missing_paths,
+        )
+        if err:
+            errors.append(err)
+        merged[key] = normalized or str(default_server_settings().get(key, ""))
+
+    return merged, errors
+
+
+def _empty_connection_payload() -> dict[str, Any]:
