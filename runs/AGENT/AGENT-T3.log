+# -*- coding: utf-8 -*-
+from __future__ import annotations
+
+from typing import Any
+from pathlib import Path
+
+from PySide6.QtCore import Qt
+from PySide6.QtWidgets import (
+    QCheckBox,
+    QComboBox,
+    QDialog,
+    QFormLayout,
+    QFrame,
+    QHBoxLayout,
+    QLabel,
+    QLineEdit,
+    QMessageBox,
+    QPushButton,
+    QFileDialog,
+    QVBoxLayout,
+)
+
+from machining_monitor_server.config_store import (
+    import_connections_from_source,
+    load_monitor_connections,
+    machining_auto_global_settings_path,
+)
+
+
+class ConnectionSettingsDialog(QDialog):
+    """Connection-only settings dialog for monitor_server."""
+
+    def __init__(
+        self,
+        *,
+        machine_list: list[str],
+        machine_conn_map: dict[str, dict[str, Any]],
+        parent=None,
+    ) -> None:
+        super().__init__(parent)
+        self.setObjectName("RotateToolDetailDialog")
+        self.setWindowFlags(Qt.Dialog | Qt.FramelessWindowHint)
+        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground, True)
+        self.setModal(True)
+
+        self._machine_list: list[str] = [str(x or "").strip() for x in list(machine_list or []) if str(x or "").strip()]
+        self._conn_map: dict[str, dict[str, Any]] = {
+            str(k or "").strip(): self._normalize_cfg(dict(v or {}))
+            for k, v in dict(machine_conn_map or {}).items()
+            if str(k or "").strip()
+        }
+        self._loading = False
+        self._selected_machine = ""
+
+        self._build_ui()
+        self._reload_machine_combo(prefer=self._machine_list[0] if self._machine_list else "")
+
+    @staticmethod
+    def _normalize_cfg(cfg: dict[str, Any]) -> dict[str, Any]:
+        out: dict[str, Any] = {
+            "connection_type": str(cfg.get("connection_type", "") or "").strip() or "HEIDENHAIN_LSV2",
+            "ip": str(cfg.get("ip", "") or "").strip(),
+            "ftp_port": 21,
+            "ftp_user": str(cfg.get("ftp_user", "") or ""),
+            "ftp_password": str(cfg.get("ftp_password", "") or ""),
+            "ftp_passive": bool(cfg.get("ftp_passive", True)),
+            "ftp_root_dir": str(cfg.get("ftp_root_dir", "") or ""),
+        }
+        try:
+            out["ftp_port"] = int(cfg.get("ftp_port", 21) or 21)
+        except Exception:
+            out["ftp_port"] = 21
+        if int(out["ftp_port"]) <= 0:
+            out["ftp_port"] = 21
+        return out
+
