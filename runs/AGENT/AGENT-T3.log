+    def _reload_machine_combo(self, *, prefer: str = "") -> None:
+        names: list[str] = []
+        seen: set[str] = set()
+        for raw in list(self._machine_list):
+            name = str(raw or "").strip()
+            if (not name) or (name in seen):
+                continue
+            names.append(name)
+            seen.add(name)
+        for raw in self._conn_map.keys():
+            name = str(raw or "").strip()
+            if (not name) or (name in seen):
+                continue
+            names.append(name)
+            seen.add(name)
+        self._machine_list = names
+
+        self.cb_machine.blockSignals(True)
+        self.cb_machine.clear()
+        for name in self._machine_list:
+            self.cb_machine.addItem(name, name)
+        self.cb_machine.blockSignals(False)
+
+        idx = -1
+        if prefer:
+            idx = self.cb_machine.findData(prefer)
+            if idx < 0:
+                idx = self.cb_machine.findText(prefer)
+        if idx < 0 and self.cb_machine.count() > 0:
+            idx = 0
+        if idx >= 0:
+            self.cb_machine.setCurrentIndex(idx)
+            self._on_machine_changed(idx)
+
+    def _store_form_to_current(self) -> None:
+        name = str(self._selected_machine or "").strip()
+        if not name:
+            return
+        try:
+            port = int((self.edt_port.text() or "21").strip())
+        except Exception:
+            port = 21
+        if port <= 0:
+            port = 21
+        self._conn_map[name] = self._normalize_cfg(
+            {
+                "connection_type": str(self.cb_conn_type.currentText() or "").strip(),
+                "ip": str(self.edt_ip.text() or "").strip(),
+                "ftp_port": int(port),
+                "ftp_user": str(self.edt_user.text() or ""),
+                "ftp_password": str(self.edt_password.text() or ""),
+                "ftp_passive": bool(self.chk_passive.isChecked()),
+                "ftp_root_dir": str(self.edt_root_dir.text() or ""),
+            }
+        )
+
+    def _load_form_from_machine(self, machine: str) -> None:
+        name = str(machine or "").strip()
+        cfg = self._normalize_cfg(dict(self._conn_map.get(name, {}) or {}))
+        self._loading = True
+        try:
+            idx = self.cb_conn_type.findText(str(cfg.get("connection_type", "HEIDENHAIN_LSV2")))
+            if idx < 0:
+                idx = 0
+            self.cb_conn_type.setCurrentIndex(idx)
+            self.edt_ip.setText(str(cfg.get("ip", "") or ""))
+            self.edt_port.setText(str(int(cfg.get("ftp_port", 21) or 21)))
+            self.edt_user.setText(str(cfg.get("ftp_user", "") or ""))
+            self.edt_password.setText(str(cfg.get("ftp_password", "") or ""))
+            self.chk_passive.setChecked(bool(cfg.get("ftp_passive", True)))
+            self.edt_root_dir.setText(str(cfg.get("ftp_root_dir", "") or ""))
+        finally:
+            self._loading = False
+        self.lbl_hint.setText(f"{name} 접속 설정")
+
+    def _on_machine_changed(self, _idx: int) -> None:
+        if self._loading:
+            return
+        self._store_form_to_current()
+        self._selected_machine = str(self.cb_machine.currentData() or self.cb_machine.currentText() or "").strip()
+        self._load_form_from_machine(self._selected_machine)
+
+    def _import_connections_from_json(self) -> None:
+        current = str(self._selected_machine or "").strip()
+        default_src = machining_auto_global_settings_path()
+        start_dir = str(default_src.parent if default_src.parent.exists() else Path.cwd())
+        path, _ = QFileDialog.getOpenFileName(
+            self,
+            "연결 설정 JSON 불러오기",
+            start_dir,
+            "JSON Files (*.json);;All Files (*)",
+        )
+        if not path:
+            return
+        try:
+            import_connections_from_source(Path(path), force=True)
+            cfg = load_monitor_connections()
+            self._machine_list = [str(x or "").strip() for x in list(cfg.get("machine_list", []) or []) if str(x or "").strip()]
+            self._conn_map = {
+                str(k or "").strip(): self._normalize_cfg(dict(v or {}))
+                for k, v in dict(cfg.get("machine_conn_map", {}) or {}).items()
+                if str(k or "").strip()
+            }
+            self._reload_machine_combo(prefer=current)
+            self.lbl_hint.setText("JSON 설정 불러오기 완료")
+        except Exception as exc:
+            self.lbl_hint.setText(f"불러오기 실패: {exc}")
+
+    def _save_current(self) -> bool:
+        self._store_form_to_current()
+        machine = str(self._selected_machine or "").strip()
+        if not machine:
+            QMessageBox.warning(self, "접속 설정", "설비를 선택하세요.")
+            return False
+        ip = str(dict(self._conn_map.get(machine, {}) or {}).get("ip", "") or "").strip()
+        if not ip:
+            QMessageBox.warning(self, "접속 설정", "IP를 입력하세요.")
+            return False
+        self.lbl_hint.setText("저장 준비 완료")
+        return True
+
+    def _accept_with_save(self) -> None:
+        if self._save_current():
+            self.accept()
+
+    def values(self) -> tuple[list[str], dict[str, dict[str, Any]], str]:
+        self._store_form_to_current()
+        return list(self._machine_list), dict(self._conn_map), str(self._selected_machine or "").strip()
