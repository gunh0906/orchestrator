+    def _sync_fleet_controls(self) -> None:
+        busy = self._server_is_transitioning()
+        can_start = self._server_state in {_SERVER_STATE_OFF, _SERVER_STATE_ERROR}
+        can_stop = self._server_state in {_SERVER_STATE_ON, _SERVER_STATE_ERROR}
+        can_restart = self._server_state in {_SERVER_STATE_ON, _SERVER_STATE_ERROR}
+        try:
+            self._btn_fleet_connect.setEnabled((not busy) and can_start and _START_FLEET_SCRIPT.exists())
+        except Exception:
+            pass
+        try:
+            self._btn_fleet_start.setEnabled((not busy) and can_start and _START_FLEET_SCRIPT.exists())
+        except Exception:
+            pass
+        try:
+            self._btn_fleet_stop.setEnabled((not busy) and can_stop and _STOP_FLEET_SCRIPT.exists())
+        except Exception:
+            pass
+        try:
+            self._btn_fleet_restart.setEnabled((not busy) and can_restart and _START_FLEET_SCRIPT.exists() and _STOP_FLEET_SCRIPT.exists())
+        except Exception:
+            pass
+        try:
+            self._btn_open_home.setEnabled(not busy)
+        except Exception:
+            pass
+
+    def _run_fleet_action_async(self, action: str, *, open_home: bool = False) -> None:
+        op = str(action or "").strip().lower()
+        allowed, reason = self._is_server_action_allowed(op)
+        if not allowed:
+            self._set_status(reason, state="warning")
+            return
+
+        self._server_action = op
+        if op in {"stop", "restart"}:
+            self._set_server_state(_SERVER_STATE_STOPPING)
+            self._emit_fleet_action_progress("STOPPING", 8, "STOPPING · 중지 준비")
+        else:
+            self._set_server_state(_SERVER_STATE_STARTING)
+            self._emit_fleet_action_progress("STARTING", 8, "STARTING · 시작 준비")
+        self._open_home_after_fleet_action = bool(open_home)
+        self._sync_fleet_controls()
+        self._set_status(f"서버 {op} 실행중", state="checking")
+        open_home_after = bool(open_home)
+
+        def _worker() -> None:
+            ok = False
+            summary = "-"
+            try:
+                if op == "start":
+                    self._emit_fleet_action_progress("STARTING", 24, "STARTING · start_fleet_collectors.ps1 실행")
+                    code, out, err = _run_powershell_file(_START_FLEET_SCRIPT)
+                    ok = int(code) == 0
+                    summary = _summarize_run("start", code, out, err)
+                    if bool(ok):
+                        self._emit_fleet_action_progress("STARTING", 92, "STARTING · 서비스 기동 확인")
+                    else:
+                        self._emit_fleet_action_progress("ERROR", 0, "STARTING · 시작 실패")
+                elif op == "stop":
+                    self._emit_fleet_action_progress("STOPPING", 24, "STOPPING · stop_fleet_collectors.ps1 실행")
+                    code, out, err = _run_powershell_file(_STOP_FLEET_SCRIPT)
+                    ok = int(code) == 0
+                    summary = _summarize_run("stop", code, out, err)
+                    if bool(ok):
+                        self._emit_fleet_action_progress("STOPPING", 92, "STOPPING · 종료 확인")
+                    else:
+                        self._emit_fleet_action_progress("ERROR", 0, "STOPPING · 중지 실패")
+                else:
+                    self._emit_fleet_action_progress("STOPPING", 20, "STOPPING · 재시작(중지 실행)")
+                    c1, o1, e1 = _run_powershell_file(_STOP_FLEET_SCRIPT)
+                    if int(c1) != 0:
+                        self._emit_fleet_action_progress("ERROR", 0, "STOPPING · 중지 단계 실패")
+                    self._emit_fleet_action_progress("STARTING", 55, "STARTING · 재시작(시작 실행)")
+                    c2, o2, e2 = _run_powershell_file(_START_FLEET_SCRIPT)
+                    ok = (int(c1) == 0) and (int(c2) == 0)
+                    summary = f"{_summarize_run('stop', c1, o1, e1)} / {_summarize_run('start', c2, o2, e2)}"
+                    if bool(ok):
+                        self._emit_fleet_action_progress("STARTING", 92, "STARTING · 서비스 기동 확인")
+                    elif int(c2) != 0:
+                        self._emit_fleet_action_progress("ERROR", 0, "STARTING · 시작 단계 실패")
+            except Exception as exc:
+                ok = False
+                summary = f"{op} failed: {exc}"
+                self._emit_fleet_action_progress("ERROR", 0, f"{str(op).upper()} · 예외 발생")
+            self.fleet_action_finished.emit(op, bool(ok), str(summary or "-"), open_home_after)
+
+        threading.Thread(target=_worker, daemon=True).start()
+
+    def _on_fleet_action_finished(self, action: str, ok: bool, summary: str, open_home: bool) -> None:
+        self._server_action = ""
+        self._open_home_after_fleet_action = False
+        op = str(action or "").strip().lower() or "action"
+        if bool(ok):
+            target = _SERVER_STATE_OFF if op == "stop" else _SERVER_STATE_ON
+            self._set_server_state(target, summary=summary)
+        else:
+            self._set_server_state(_SERVER_STATE_ERROR, summary=summary)
+
+        if bool(ok):
+            self._set_status(f"서버 {op} 완료", state="checking")
+            if op == "stop":
+                self._emit_fleet_action_progress("OFFLINE", 100, "서버 오프라인")
+            else:
+                self._emit_fleet_action_progress("ONLINE", 100, "서버 온라인")
+            if bool(open_home) and op in {"start", "restart"}:
+                threading.Thread(target=self._open_home_when_ready, daemon=True).start()
+        else:
+            self._set_status(f"서버 {op} 실패", state="error")
+            self._emit_fleet_action_progress("ERROR", 0, "서버 전환 실패")
+            if not self._shutting_down:
+                try:
+                    QMessageBox.warning(
+                        self._dialog,
+                        "서버 제어 실패",
+                        f"서버 {op} 작업이 실패했습니다.\n\n{summary or '-'}",
+                    )
+                except Exception:
+                    pass
+
+        try:
+            self._lbl_state.setToolTip(str(summary or "-"))
+        except Exception:
+            pass
 
