+def _safe_machine_token(machine: str) -> str:
+    txt = str(machine or "").strip()
+    if not txt:
+        return ""
+    token = re.sub(r"[^0-9A-Za-z_#\-.]+", "_", txt)
+    token = re.sub(r"_+", "_", token).strip("_")
+    return token or txt
+
+
+def _tail_log_text(path: Path, *, max_lines: int = _LOG_TAIL_LINES) -> str:
+    p = Path(path)
+    if not p.exists():
+        return f"(missing) {p}"
+    try:
+        text = p.read_text(encoding="utf-8", errors="replace")
+    except Exception as exc:
+        return f"(read failed) {p} - {exc}"
+
+    lines = list(text.splitlines())
+    if not lines:
+        return "(empty)"
+    tail = lines[-max(1, int(max_lines)) :]
+    if len(lines) > len(tail):
+        tail.insert(0, f"... {len(lines) - len(tail)} lines omitted ...")
+    return "\n".join(tail)
+
+
