+    def _detect_initial_server_state(self) -> str:
+        if _FLEET_PID_FILE.exists():
+            return _SERVER_STATE_ON
+        return _SERVER_STATE_OFF
+
+    def _set_server_state(self, state: str, *, summary: str = "") -> None:
+        st = str(state or "").strip().upper()
+        if st not in _SERVER_STATES:
+            st = _SERVER_STATE_ERROR
+        self._server_state = st
+        self._server_last_summary = str(summary or "").strip()
+        self._sync_fleet_controls()
+        self._sync_server_transition_ui()
+
+    @staticmethod
+    def _dialog_server_transition_token(state: str) -> str:
+        st = str(state or "").strip().upper()
+        if st == _SERVER_STATE_ON:
+            return "ONLINE"
+        if st == _SERVER_STATE_OFF:
+            return "OFFLINE"
+        if st == _SERVER_STATE_STARTING:
+            return "STARTING"
+        if st == _SERVER_STATE_STOPPING:
+            return "STOPPING"
+        return "ERROR"
+
+    def _sync_server_transition_ui(self, *, step_text: str = "", progress: int | None = None) -> None:
+        fn = getattr(self._dialog, "set_fleet_server_transition", None)
+        if not callable(fn):
+            return
+        token = self._dialog_server_transition_token(self._server_state)
+        if progress is None:
+            if token == "ONLINE":
+                progress = 100
+            elif token == "OFFLINE":
+                progress = 0
+        try:
+            fn(token, step_text=str(step_text or ""), progress=progress)
+        except Exception:
+            pass
+
+    def _emit_fleet_action_progress(self, transition: str, progress: int, step_text: str) -> None:
+        try:
+            self.fleet_action_progress.emit(str(transition or ""), str(step_text or ""), int(progress))
+        except Exception:
+            pass
+
+    def _on_fleet_action_progress(self, transition: str, step_text: str, progress: int) -> None:
+        fn = getattr(self._dialog, "set_fleet_server_transition", None)
+        if not callable(fn):
+            return
+        try:
+            fn(str(transition or ""), step_text=str(step_text or ""), progress=int(progress))
+        except Exception:
+            pass
+
+    def _server_is_transitioning(self) -> bool:
+        return self._server_state in {_SERVER_STATE_STARTING, _SERVER_STATE_STOPPING}
+
+    def _is_server_action_allowed(self, action: str) -> tuple[bool, str]:
+        op = str(action or "").strip().lower()
+        if op not in {"start", "stop", "restart"}:
+            return False, "지원하지 않는 서버 작업"
+        if self._server_is_transitioning():
+            return False, "서버 전환중"
+        if op == "start" and self._server_state == _SERVER_STATE_ON:
+            return False, "서버 이미 실행중"
+        if op == "stop" and self._server_state == _SERVER_STATE_OFF:
+            return False, "서버 이미 중지됨"
+        if op == "restart" and self._server_state == _SERVER_STATE_OFF:
+            return False, "서버 중지 상태에서는 재시작 불가"
+        return True, ""
+
+    @staticmethod
+    def is_equipment_online(
+        *,
+        connection_state: object,
+        latest_sample_age: object,
+        max_sample_age_sec: int,
+    ) -> bool:
+        state = str(connection_state or "").strip().lower()
+        if state not in {"connected", "online", "active"}:
+            return False
+        try:
+            age = int(latest_sample_age)
+        except Exception:
+            return False
+        return 0 <= age <= max(1, int(max_sample_age_sec))
+
+    def _equipment_online_age_limit_sec(self) -> int:
+        return max(8, int(self._graph_period_sec) * 6)
+
+    def _equipment_is_online(self) -> bool:
+        return self.is_equipment_online(
+            connection_state=self._equipment_connection_state,
+            latest_sample_age=self._equipment_latest_sample_age_sec,
+            max_sample_age_sec=self._equipment_online_age_limit_sec(),
+        )
+
+    def _set_equipment_connection_state(self, state: str) -> None:
+        raw = str(state or "").strip().lower()
+        if raw in {"online", "active"}:
+            raw = "connected"
+        if raw not in {"connected", "connecting", "disconnecting", "disconnected", "error"}:
+            raw = "disconnected"
+        self._equipment_connection_state = raw
+
+    def _apply_equipment_status_from_snapshot(self, fallback_text: str = "미연결") -> None:
+        state = str(self._equipment_connection_state or "disconnected")
+        if state == "connecting":
+            self._set_status("연결중", state="checking")
+            return
+        if state == "disconnecting":
+            self._set_status("연결해제중", state="checking")
+            return
+        if state == "error":
+            self._set_status("연결 오류", state="error")
+            return
+        if self._equipment_is_online():
+            self._set_status("연결됨", state="connected")
+            return
+        if state == "connected":
+            self._set_status("수집 지연", state="warning")
+            return
+        self._set_status(str(fallback_text or "미연결"), state="disconnected")
+
+    def _update_sample_age_from_payload(self, payload: object) -> None:
+        age_sec = -1
+        if isinstance(payload, dict):
+            try:
+                summary = dict(payload.get("summary", {}) or {})
+                ep = self._runtime_to_int(summary.get("runtime_epoch"))
+                if ep is not None and ep > 0:
+                    age_sec = max(0, int(time.time()) - int(ep))
+            except Exception:
+                age_sec = -1
+        self._equipment_latest_sample_age_sec = int(age_sec)
+
+    def _show_connect_toggle_rollback(self, message: str) -> None:
+        self._set_connect_button_checked(self._connected)
+        self._btn_connect.setToolTip(str(message or "연결 작업 실패 (원복됨)").strip() or "연결 작업 실패 (원복됨)")
+        try:
+            self._btn_connect.setProperty("rollback", True)
+            self._btn_connect.style().unpolish(self._btn_connect)
+            self._btn_connect.style().polish(self._btn_connect)
+            self._btn_connect.update()
+            QTimer.singleShot(900, self._clear_connect_toggle_rollback)
+        except Exception:
+            pass
+
+    def _clear_connect_toggle_rollback(self) -> None:
+        try:
+            self._btn_connect.setProperty("rollback", False)
+            self._btn_connect.style().unpolish(self._btn_connect)
+            self._btn_connect.style().polish(self._btn_connect)
+            self._btn_connect.update()
+        except Exception:
+            pass
+
+    def shutdown(self) -> None:
+        if self._shutting_down:
+            return
+        self._shutting_down = True
+        self._runtime_history_end_session(note="controller_shutdown")
+        try:
+            self._poll_timer.stop()
+        except Exception:
+            pass
+        try:
+            should_stop_fleet = (_FLEET_PID_FILE.exists()) or (self._server_state in {_SERVER_STATE_ON, _SERVER_STATE_STARTING, _SERVER_STATE_ERROR})
+            if should_stop_fleet and _STOP_FLEET_SCRIPT.exists():
+                self._set_server_state(_SERVER_STATE_STOPPING)
+                code, out, err = _run_powershell_file(_STOP_FLEET_SCRIPT)
+                summary = _summarize_run("stop", code, out, err)
+                self._set_server_state(_SERVER_STATE_OFF if int(code) == 0 else _SERVER_STATE_ERROR, summary=summary)
+        except Exception:
+            self._set_server_state(_SERVER_STATE_ERROR)
+        try:
+            shutdown = getattr(self._conn_mgr, "shutdown", None)
+            if callable(shutdown):
+                shutdown(3500)
+            else:
+                self._conn_mgr.disconnect_machine()
+        except Exception:
+            pass
+        self._conn_action_pending = ""
+        self._is_connecting = False
+        self._connected = False
+        self._set_equipment_connection_state("disconnected")
+        self._equipment_latest_sample_age_sec = -1
+        self._connect_toggle_action_inflight = False
+        self._set_connect_button_checked(False)
+        self._apply_equipment_status_from_snapshot("미연결")
+        try:
+            if self._runtime_history_store is not None:
+                self._runtime_history_store.close()
+        except Exception:
+            pass
 
