+        default_step = "서버 대기"
+
+        if token in {"STARTING", "START", "BOOTING"}:
+            badge_state = "starting"
+            badge_text = "온라인"
+            default_step = "STARTING"
+            show_progress = True
+        elif token in {"STOPPING", "STOP", "SHUTTING_DOWN"}:
+            badge_state = "stopping"
+            badge_text = "오프라인"
+            default_step = "STOPPING"
+            show_progress = True
+        elif token in {"ONLINE", "RUNNING", "READY", "STARTED"}:
+            badge_state = "online"
+            badge_text = "온라인"
+            default_step = "서버 온라인"
+            if progress is None:
+                progress = 100
+        elif token in {"OFFLINE", "STOPPED", "IDLE"}:
+            badge_state = "offline"
+            badge_text = "오프라인"
+            default_step = "서버 오프라인"
+            if progress is None:
+                progress = 0
+        elif token in {"ERROR", "FAILED", "FAIL"}:
+            badge_state = "error"
+            badge_text = "오프라인"
+            default_step = "전환 실패"
+            if progress is None:
+                progress = 0
+
