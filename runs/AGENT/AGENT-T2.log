+                e = int(seg.get("end_epoch", s) or s)
+                if e <= s:
+                    continue
+                if e <= day_timeline_start_ep or s >= day_timeline_end_ep:
+                    continue
+                timeline.append(
+                    {
+                        "start_epoch": int(max(day_timeline_start_ep, s)),
+                        "end_epoch": int(min(day_timeline_end_ep, e)),
+                        "state": _timeline_state_for_card(seg.get("state", "standby")),
+                    }
+                )
+            timeline = _to_remaining_future(
+                timeline,
