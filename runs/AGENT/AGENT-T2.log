+    def set_day_timeline(
+        self,
+        *,
+        segments: list[dict[str, Any]] | None,
+        start_epoch: int | None,
+        end_epoch: int | None,
+    ) -> None:
+        try:
+            s_ep = int(start_epoch) if start_epoch is not None else 0
+        except Exception:
+            s_ep = 0
+        try:
+            e_ep = int(end_epoch) if end_epoch is not None else 0
+        except Exception:
+            e_ep = 0
+        if e_ep <= s_ep:
+            self._timeline_segments = []
+            self._timeline_start_epoch = 0
+            self._timeline_end_epoch = 0
+            self.update()
+            return
+        normalized: list[dict[str, Any]] = []
+        for seg in list(segments or []):
+            try:
+                a = int(seg.get("start_epoch", s_ep) or s_ep)
+                b = int(seg.get("end_epoch", a) or a)
+            except Exception:
+                continue
+            if b <= a:
+                continue
+            if b <= s_ep or a >= e_ep:
+                continue
+            st = str(seg.get("state", "standby") or "standby").strip().lower()
+            if st not in {"running", "standby", "alarm", "offline", "remaining"}:
+                st = "standby"
+            normalized.append(
+                {
+                    "start_epoch": int(max(s_ep, a)),
+                    "end_epoch": int(min(e_ep, b)),
+                    "state": st,
+                }
+            )
+        merged: list[dict[str, Any]] = []
+        for seg in normalized:
+            if (
+                merged
+                and str(merged[-1].get("state", "")) == str(seg.get("state", ""))
+                and int(merged[-1].get("end_epoch", 0) or 0) >= int(seg.get("start_epoch", 0) or 0)
+            ):
+                merged[-1]["end_epoch"] = int(
+                    max(
+                        int(merged[-1].get("end_epoch", 0) or 0),
+                        int(seg.get("end_epoch", 0) or 0),
+                    )
+                )
+            else:
+                merged.append(dict(seg))
+        self._timeline_segments = merged
+        self._timeline_start_epoch = int(s_ep)
+        self._timeline_end_epoch = int(e_ep)
+        self.update()
