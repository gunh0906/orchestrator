+    def resizeEvent(self, event) -> None:  # noqa: ANN001
+        super().resizeEvent(event)
+        rows = list(getattr(self, "_fleet_card_rows_cache", []) or [])
+        scroll = getattr(self, "scroll_hist_fleet_cards", None)
+        if (not rows) or (scroll is None):
+            return
+        viewport_w = self._fleet_cards_viewport_width()
