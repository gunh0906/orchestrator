+    def _fleet_ratio_pct(numerator: Any, denominator: Any) -> float | None:
+        try:
+            num = float(numerator or 0.0)
+            den = float(denominator or 0.0)
+        except Exception:
+            return None
+        if den <= 0.0:
+            return None
+        return (num / den) * 100.0
+
+    @staticmethod
+    def _fleet_card_layout_for_width(viewport_w: int) -> tuple[int, int, int]:
+        width = max(0, int(viewport_w))
+        spacing = 8 if width >= 1500 else 10
+        min_card_width = 188
+        max_card_width = 260
+        if width >= 1680:
+            preferred_cols = 8
+        elif width >= 1360:
+            preferred_cols = 6
+        elif width >= 1040:
+            preferred_cols = 4
+        elif width >= 740:
+            preferred_cols = 3
+        elif width >= 500:
+            preferred_cols = 2
+        else:
+            preferred_cols = 1
+        max_cols_by_min = max(1, int((width + spacing) // (min_card_width + spacing)))
+        cols = max(1, min(int(preferred_cols), int(max_cols_by_min)))
+        raw_card_width = int((width - ((cols - 1) * spacing)) / max(1, cols))
+        card_width = max(min_card_width, min(max_card_width, raw_card_width))
+        return cols, card_width, spacing
+
+    def _fleet_cards_viewport_width(self) -> int:
+        viewport_w = 0
+        scroll = getattr(self, "scroll_hist_fleet_cards", None)
+        if scroll is not None:
+            try:
+                viewport_w = int(scroll.viewport().width())
+            except Exception:
+                viewport_w = 0
+        if viewport_w <= 0:
+            try:
+                viewport_w = int(self._fleet_cards_viewport.width())
+            except Exception:
+                viewport_w = 0
+        if viewport_w <= 0 and bool(getattr(self, "_fleet_last_viewport_width", -1) > 0):
+            viewport_w = int(self._fleet_last_viewport_width)
+        if viewport_w <= 0:
+            try:
+                viewport_w = max(0, int(self.width()) - 240)
+            except Exception:
+                viewport_w = 0
+        return max(0, int(viewport_w))
+
+    def _schedule_fleet_cards_relayout(self) -> None:
+        rows = list(getattr(self, "_fleet_card_rows_cache", []) or [])
+        if not rows:
+            return
+        self._fleet_relayout_token = int(getattr(self, "_fleet_relayout_token", 0) or 0) + 1
+        token = int(self._fleet_relayout_token)
+
+        def _run_pass() -> None:
+            if int(getattr(self, "_fleet_relayout_token", -1)) != token:
+                return
+            live_rows = list(getattr(self, "_fleet_card_rows_cache", []) or [])
+            if not live_rows:
+                return
+            self._fleet_last_viewport_width = -1
+            self._render_history_fleet_cards(live_rows)
+
+        QTimer.singleShot(0, _run_pass)
+        QTimer.singleShot(80, _run_pass)
+
+    def set_fleet_server_transition(
+        self,
+        transition_state: str,
+        *,
+        step_text: str = "",
+        progress: int | None = None,
+    ) -> None:
+        token = str(transition_state or "").strip().upper()
+        show_progress = False
+        badge_state = "offline"
+        badge_text = "오프라인"
+        default_step = "서버 대기"
+
+        if token in {"STARTING", "START", "BOOTING"}:
+            badge_state = "starting"
+            badge_text = "온라인"
+            default_step = "STARTING"
+            show_progress = True
+        elif token in {"STOPPING", "STOP", "SHUTTING_DOWN"}:
+            badge_state = "stopping"
+            badge_text = "오프라인"
+            default_step = "STOPPING"
+            show_progress = True
+        elif token in {"ONLINE", "RUNNING", "READY", "STARTED"}:
+            badge_state = "online"
+            badge_text = "온라인"
+            default_step = "서버 온라인"
+            if progress is None:
+                progress = 100
+        elif token in {"OFFLINE", "STOPPED", "IDLE"}:
+            badge_state = "offline"
+            badge_text = "오프라인"
+            default_step = "서버 오프라인"
+            if progress is None:
+                progress = 0
+        elif token in {"ERROR", "FAILED", "FAIL"}:
+            badge_state = "error"
+            badge_text = "오프라인"
+            default_step = "전환 실패"
+            if progress is None:
+                progress = 0
+
+        badge = getattr(self, "lbl_hist_server_state", None)
+        if badge is not None:
+            badge.setText(str(badge_text))
+            if str(badge.property("server_state") or "") != badge_state:
+                badge.setProperty("server_state", badge_state)
+                badge.style().unpolish(badge)
+                badge.style().polish(badge)
+                badge.update()
+
+        step_lbl = getattr(self, "lbl_hist_server_step", None)
+        if step_lbl is not None:
+            step_line = str(step_text or "").strip() or str(default_step)
+            step_lbl.setText(step_line)
+
+        bar = getattr(self, "bar_hist_server_progress", None)
+        if bar is not None:
+            if progress is not None:
+                bar.setValue(max(0, min(100, int(progress))))
+            bar.setVisible(bool(show_progress))
+
+    def _toggle_history_advanced_sections(self, checked: bool) -> None:
+        show_adv = bool(checked)
+        table_wrap = getattr(self, "_fleet_table_wrap", None)
         donut_wrap = getattr(self, "_history_donut_wrap", None)
