+    def _render_history_fleet_cards(self, rows: list[dict[str, Any]]) -> None:
+        grid = getattr(self, "_fleet_cards_grid", None)
+        scroll = getattr(self, "scroll_hist_fleet_cards", None)
+        if grid is None or scroll is None:
+            return
+        self._fleet_card_rows_cache = [dict(r or {}) for r in list(rows or [])]
+
+        viewport_w = self._fleet_cards_viewport_width()
+        if viewport_w <= 0 and rows:
+            self._fleet_last_viewport_width = -1
+            return
+        self._fleet_last_viewport_width = int(viewport_w)
