+    def _normalize_fleet_state(state: Any, raw_state: Any = "") -> str:
+        st = str(state or "").strip().lower()
+        raw = str(raw_state or "").strip().lower()
+        if st == "manual":
+            return "manual"
+        if st == "alarm":
+            return "alarm"
+        if st in {"offline", "network_lost", "plc_timeout"}:
+            return "offline"
+        if st in {"running", "cutting"}:
+            return "running"
+        if st == "connected":
+            return "idle"
+        if st == "idle":
+            if raw in {"stopped", "stop", "ready", "reset"}:
+                return "stop"
+            return "idle"
+        if st == "stop":
+            return "stop"
+        if raw in {"stopped", "stop", "ready", "reset"}:
+            return "stop"
+        return "idle"
