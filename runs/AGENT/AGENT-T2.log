+        def _to_remaining_future(
+            segments: list[dict[str, Any]],
+            *,
+            now_ep: int,
+            start_ep: int,
+            end_ep: int,
+        ) -> list[dict[str, Any]]:
+            if not (int(start_ep) <= int(now_ep) < int(end_ep)):
+                return [dict(seg or {}) for seg in list(segments or [])]
+            out: list[dict[str, Any]] = []
+            for seg in list(segments or []):
+                s = int(seg.get("start_epoch", start_ep) or start_ep)
+                e = int(seg.get("end_epoch", s) or s)
+                if e <= s:
+                    continue
+                st = str(seg.get("state", "standby") or "standby").strip().lower()
+                if s < int(now_ep) < e:
+                    left = {"start_epoch": int(s), "end_epoch": int(now_ep), "state": st}
+                    right = {"start_epoch": int(now_ep), "end_epoch": int(e), "state": "remaining"}
+                    out.append(left)
+                    out.append(right)
+                elif s >= int(now_ep):
+                    out.append({"start_epoch": int(s), "end_epoch": int(e), "state": "remaining"})
+                else:
+                    out.append({"start_epoch": int(s), "end_epoch": int(e), "state": st})
+            return out
+
